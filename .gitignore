# Build artifacts and large binaries — never committed
build/out/
build/cache/
build/uboot-*/
*.bin
*.fit
*.img
*.ext4
*.simg
*.tar
*.dtb
Image
Image.gz
zImage*
# Pinned source trees are fetched by the build, not vendored
linux-*/
rootfs-build/
# Proprietary/local-only recovery material — keep in the workspace, never Git
local/

# Editor/OS cruft
*.swp
.DS_Store
__pycache__/
*.pyc
