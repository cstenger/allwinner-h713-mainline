# H713 mainline — pinned versions (single source of truth for build/build.sh)
# Sourced as shell. Component *sources* are the git submodules under external/;
# the exact commit is the submodule gitlink. The bases below record which
# upstream each curated series sits on, for provenance and rebases.

# --- TF-A BL31 (external/arm-trusted-firmware @ sun50i-h713) ---
ATF_BASE=347d1c164          # upstream TF-A commit the sun50i_h713 series is on
ATF_PLAT=sun50i_h713

# --- U-Boot (external/u-boot @ h713) ---
UBOOT_BASE=f605dcee103      # upstream U-Boot commit the h713 series is on
UBOOT_DEFCONFIG_DDR3=hy200_qz713df_a1_defconfig    # HY200 QZ713DF_A1 bench (DDR3)
UBOOT_DEFCONFIG_LPDDR3=hy200_qz713_v2_defconfig     # HY200 QZ713_V2 projector (LPDDR3)

# --- sunxi-tools (external/sunxi-tools @ h713) ---
SUNXITOOLS_BASE=7540cb2     # upstream sunxi-tools commit the h713 series is on

# --- Linux kernel (mainline tarball + patches/kernel/) ---
KERNEL_VERSION=6.18.38                              # LTS; boot-good on HY200 QZ713DF_A1
KERNEL_TARGET=6.18.38                               # current target (see docs/kernel-bump.md)
KERNEL_ARCH=arm64
KERNEL_DEFCONFIG=hy200_qz713df_a1_defconfig            # bench (HY200 QZ713DF_A1)
KERNEL_DTB=sun50i-h713-hy200-qz713df-a1              # arm64 board DTB (patch 0024, bench)
KERNEL_DTB_PROJECTOR=sun50i-h713-hy200-qz713-v2       # arm64 projector DTB (untested on hardware)
KERNEL_TARBALL_URL="https://cdn.kernel.org/pub/linux/kernel/v6.x/linux-${KERNEL_VERSION}.tar.xz"
KERNEL_TARBALL_SHA256=ac26e508abd56e9f8b89872b6e10c49fc823bcc70d8068a5d8504c1a7c4ff045

# --- AIC8800 WiFi/BT (out-of-tree modules under modules/aic8800/) ---
# WiFi over SDIO (mmc1), BT over UART HCI. The driver is GPL and in-tree here;
# the firmware is a proprietary Aicsemi blob with no open equivalent, so it is
# NOT committed — it is pinned by SHA-256 and copied into the rootfs at build
# time from the local-only source of record. Paths are relative to the repo root.
AIC8800_FW_SRC=local/allwinner-h713-linux/drivers/wifi/firmware/aic8800_sdio/aic8800D80
AIC8800_FW_SUMS=modules/aic8800/firmware.sha256sums   # tracked checksum manifest (pin)
AIC8800_FW_DEST=usr/lib/firmware/aic8800_sdio/aic8800  # rootfs dir = driver's CONFIG_AIC_FW_PATH

# --- Debian root filesystem ---
DEBIAN_SUITE=trixie
DEBIAN_ARCH=arm64
DEBIAN_MIRROR=https://deb.debian.org/debian
DEBIAN_ARCHIVE_KEYRING=/usr/share/keyrings/debian-archive-keyring.gpg
ROOTFS_IMAGE_SIZE=2G

# --- Memory map / load addresses (see docs/bringup-notes.md) ---
BL31_BASE=0x40000000        # BL31_IN_DRAM
KERNEL_LOAD=0x48000000      # FIT load/entry (arm64 Image), keeps clear of BL31
